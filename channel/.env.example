
# ── Email (SMTP) — real sending ───────────────────────────────────────
# Example providers:
#   Brevo:    SMTP_HOST=smtp-relay.brevo.com  SMTP_PORT=587  (login = brevo login, password = SMTP key)
#   Gmail:    SMTP_HOST=smtp.gmail.com        SMTP_PORT=587  (password = 16-char App Password)
#   Resend:   SMTP_HOST=smtp.resend.com       SMTP_PORT=465  SMTP_USE_SSL=true  (username=resend, password=API key)
#   SendGrid: SMTP_HOST=smtp.sendgrid.net     SMTP_PORT=587  (username=apikey, password=API key)
SMTP_HOST=
SMTP_PORT=587
SMTP_USE_TLS=true
SMTP_USE_SSL=false
SMTP_USERNAME=
SMTP_PASSWORD=
EMAIL_FROM=campaigns@yourbrand.com
EMAIL_FROM_NAME=Your Brand

# ── SMS / WhatsApp (Twilio) ───────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_SMS_FROM=+1XXXXXXXXXX
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# ── Supabase ──────────────────────────────────────────────────────────
# NOTE: URL is the project REST endpoint, NOT the secret key.
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGci...                       # service role key (keep secret, never commit)

# ── Groq ──────────────────────────────────────────────────────────────
GROQ_API_KEY=gsk_XXXXXXXXXXXXXXXXXXXXXXXX
GROQ_MODEL=llama-3.3-70b-versatile

# ── Redis / Celery ────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
# Real Redis + worker processes are running, so tasks run via the broker.
CELERY_TASK_ALWAYS_EAGER=false

# ── Inter-service ─────────────────────────────────────────────────────
CHANNEL_SERVICE_URL=http://localhost:8001

# ── App ───────────────────────────────────────────────────────────────
PORT=8000
DEBUG=true
SECRET_KEY=local-dev-secret-change-me
ALLOWED_ORIGINS=http://localhost:3000
